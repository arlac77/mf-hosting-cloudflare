{
  "name": "mf-hosting-cloudflare",
  "version": "0.0.0-semantic-release",
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "npm@11.16.0",
  "description": "hosting definitions for cloudflare @MF",
  "keywords": [
    "npm-pkgbuild"
  ],
  "contributors": [
    {
      "name": "Markus Felten",
      "email": "markus.felten@gmx.de"
    }
  ],
  "license": "0BSD",
  "devDependencies": {
    "semantic-release": "^25.0.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arlac77/mf-hosting-cloudflare.git"
  },
  "bugs": {
    "url": "https://github.com/arlac77/mf-hosting-cloudflare/issues"
  },
  "homepage": "https://github.com/arlac77/mf-hosting-cloudflare#readme",
  "pkgbuild": {
    "html_base_href": "/",
    "http_path": "/",
    "install_dir": "/",
    "requires": {
      "properties": {
        "frontend": true
      },
      "environment": {
        "has": "CF_PAGE"
      }
    },
    "variant": "mf.cloudflare.pages"
  },
  "template": {
    "inheritFrom": [
      "arlac77/template-arlac77-github",
      "arlac77/template-npm",
      "arlac77/template-semantic-release"
    ]
  }
}
